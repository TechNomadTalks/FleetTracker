# Server Environment Variables

# Required - For SQLite local testing (use postgresql:// for production)
DATABASE_URL=file:./dev.db

# Required - Generate a strong random string (e.g., openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# Optional
PORT=5000
NODE_ENV=development

# Optional - For admin registration (set this to a secure secret)
ADMIN_SECRET=your-admin-secret

# Optional - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Optional - Seed passwords (if not set, random passwords are generated)
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=

# Optional - SMTP Configuration (email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=FleetTracker <noreply@fleettracker.com>

# Optional - WebPush VAPID Keys (generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Optional - Client URL for email links
# CLIENT_URL=http://localhost:5173
